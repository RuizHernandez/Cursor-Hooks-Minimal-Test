{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "node .cursor/hooks/protected-path-guard.js",
        "matcher": ".*",
        "timeout": 10
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/protected-path-guard.js",
        "matcher": ".*",
        "timeout": 10
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/protected-path-guard.js",
        "matcher": ".*",
        "timeout": 10
      }
    ]
  }
}
